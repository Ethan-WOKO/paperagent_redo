# Copy this file to the repository root as .env.sandbox.local.
# It is loaded only by the local Broker and is ignored by Git.
YANBAN_SANDBOX_BROKER_ENABLED=true
YANBAN_SANDBOX_BROKER_PROVIDER=E2B
YANBAN_SANDBOX_BROKER_MODE=LOCAL_ACCEPTANCE
YANBAN_SANDBOX_BROKER_ADDRESS=127.0.0.1
YANBAN_SANDBOX_BROKER_REMOTE=false
YANBAN_SANDBOX_WORKSPACE_ROOT=C:/Users/your-user/AppData/Local/Temp/yanban-sandbox-work
YANBAN_SANDBOX_BROKER_TOKEN=replace-with-the-same-random-token-used-by-the-api

YANBAN_SANDBOX_DB_URL=jdbc:mysql://127.0.0.1:3307/yanban_sandbox?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
YANBAN_SANDBOX_DB_USER=yanban_sandbox_broker
YANBAN_SANDBOX_DB_PASSWORD=replace-with-a-local-random-database-password

E2B_API_KEY=replace-with-your-e2b-api-key
YANBAN_E2B_TEMPLATE=yanban-research-v1
YANBAN_E2B_PYTHON_EXECUTABLE=C:/Users/your-user/AppData/Local/Temp/yanban-e2b-test-venv/Scripts/python.exe
YANBAN_E2B_HELPER=C:/java_file/private_helper_Agent/private-helper-test(0708)/deploy/sandbox/e2b/e2b_provider.py
