# Install only after an administrator provisions these certificate files and
# restricts 8443 to the local container bridge with the host firewall.
server {
    listen 8443 ssl;
    server_name host.docker.internal;
    ssl_certificate     /etc/yanban-sandbox/tls/broker.crt;
    ssl_certificate_key /etc/yanban-sandbox/tls/broker.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    client_max_body_size 22m;

    location /internal/v1/ {
        proxy_pass http://127.0.0.1:8091;
        proxy_connect_timeout 3s;
        proxy_read_timeout 20s;
        proxy_request_buffering on;
        proxy_buffering on;
    }
}
